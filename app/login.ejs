<div id="loginContainer" class="view-container" style="display: none;">
    <div id="loginCancelContainer" style="position: absolute; top: 30px; right: 30px;">
        <button id="loginCancelButton" class="btn-minecraft btn-stone-mc btn-small">
            <span id="loginCancelText"><%- lang('login.loginCancelText') %></span>
        </button>
    </div>
    
    <div id="loginContent" class="modal-content">
        <form id="loginForm" style="display: flex; flex-direction: column; width: 100%; max-width: 320px; align-items: center;">
            <img id="loginImageSeal" src="assets/images/CSMP_logo.png" style="max-width: 100px; margin-bottom: 20px;" />
            <h3 id="loginSubheader" style="color: var(--text-dark); margin-bottom: 25px; text-transform: uppercase; font-size: 13px; letter-spacing: 2px;"><%- lang('login.loginSubheader') %></h3>
            
            <div class="loginFieldContainer" style="width: 100%; position: relative; margin-bottom: 15px;">
                <span class="loginErrorSpan" id="loginEmailError" style="color: var(--mc-red); font-size: 10px; font-weight: bold; position: absolute; right: 0; top: -16px; opacity: 0; transition: var(--transition);"><%- lang('login.loginEmailError') %></span>
                <input id="loginUsername" class="input-mc" type="text" placeholder="<%- lang('login.loginEmailPlaceholder') %>" style="width: 100%; text-align: center;"/>
            </div>
            
            <div class="loginFieldContainer" style="width: 100%; position: relative; margin-bottom: 15px;">
                <span class="loginErrorSpan" id="loginPasswordError" style="color: var(--mc-red); font-size: 10px; font-weight: bold; position: absolute; right: 0; top: -16px; opacity: 0; transition: var(--transition);"><%- lang('login.loginPasswordError') %></span>
                <input id="loginPassword" class="input-mc" type="password" placeholder="<%- lang('login.loginPasswordPlaceholder') %>" style="width: 100%; text-align: center;"/>
            </div>
            
            <div id="loginOptions" style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 25px;">
                <span class="loginSpanDim">
                    <a href="<%- lang('login.loginForgotPasswordLink') %>" style="font-size: 11px; font-weight: bold;"><%- lang('login.loginForgotPasswordText') %></a>
                </span>
                <label id="checkmarkContainer" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                    <input id="loginRememberOption" type="checkbox" checked style="display: none;">
                    <div style="width: 16px; height: 16px; border: 2px solid var(--text-muted); display: flex; justify-content: center; align-items: center; background: var(--bg-input);">
                        <div id="loginRememberCheck" style="width: 8px; height: 8px; background: var(--mc-green); display: block;"></div>
                    </div>
                    <span id="loginRememberText" class="loginSpanDim" style="color: var(--text-muted); font-size: 11px; font-weight: bold;"><%- lang('login.loginRememberMeText') %></span>
                </label>
            </div>
            
            <button id="loginButton" class="btn-minecraft btn-green-mc" disabled style="width: 100%; margin-bottom: 20px;">
                <span id="loginButtonContent">
                    <%- lang('login.loginButtonText') %>
                </span>
            </button>
            
            <div id="loginDisclaimer" style="text-align: center; display: flex; flex-direction: column; gap: 5px;">
                <span class="loginSpanDim" id="loginRegisterSpan">
                    <a href="<%- lang('login.loginNeedAccountLink') %>" style="font-size: 11px; font-weight: bold;"><%- lang('login.loginNeedAccountText') %></a>
                </span>
                <p class="loginDisclaimerText" style="color: var(--text-muted); font-size: 9px; margin-top: 10px;"><%- lang('login.loginPasswordDisclaimer1') %></p>
                <p class="loginDisclaimerText" style="color: var(--text-muted); font-size: 9px;"><%- lang('login.loginPasswordDisclaimer2', { appName: lang('app.title') }) %></p>
            </div>
        </form>
    </div>
    
    <style>
        #checkmarkContainer input:checked ~ div > #loginRememberCheck { display: block; }
        #checkmarkContainer input:not(:checked) ~ div > #loginRememberCheck { display: none; }
        .shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
        @keyframes shake {
            10%, 90% { transform: translate3d(-1px, 0, 0); }
            20%, 80% { transform: translate3d(2px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
            40%, 60% { transform: translate3d(4px, 0, 0); }
        }
    </style>
    <script src="./assets/js/scripts/login.js"></script>
</div>