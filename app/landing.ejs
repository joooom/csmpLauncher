<div id="landingContainer" style="display: none;">
    
    <!-- Navbar -->
    <header class="landing-nav">
        <div class="landing-brand">
            <img src="assets/images/CSMP_logo.png" alt="CSMP Logo" id="image_seal">
            <button id="server_selection_button" class="btn-minecraft btn-stone-mc btn-small" style="margin-left: 10px;">
                <%- lang('landing.launchButtonPlaceholder') %>
            </button>
        </div>
        
        <div class="landing-nav-right">
            <div class="landing-user" id="profileDropdownTrigger">
                <span id="user_text" class="landing-user-text"><%- lang('landing.usernamePlaceholder') %></span>
                <div id="avatarContainer" class="landing-avatar"></div>
                <div class="profile-dropdown-arrow">&#9662;</div>
                
                <div class="profile-dropdown" id="profileDropdown">
                    <div id="profileDropdownList"></div>
                    <div class="profile-add-btn" id="profileDropdownAdd">+ ADD ACCOUNT</div>
                </div>
            </div>
            
            <button class="landing-settings-btn" id="settingsMediaButton">
                <svg id="settingsSVG" viewBox="0 0 141.36 137.43">
                    <path d="M70.70475616319865,83.36934004916053 a15.320781354859122,15.320781354859122 0 1 1 14.454501310561755,-15.296030496450625 A14.850515045097694,14.850515045097694 0 0 1 70.70475616319865,83.36934004916053 M123.25082856443602,55.425620905968366 h-12.375429204248078 A45.54157947163293,45.54157947163293 0 0 0 107.21227231573047,46.243052436416285 l8.613298726156664,-9.108315894326587 a9.727087354538993,9.727087354538993 0 0 0 0,-13.167456673319956 l-3.465120177189462,-3.6631270444574313 a8.489544434114185,8.489544434114185 0 0 0 -12.375429204248078,0 l-8.613298726156664,9.108315894326587 A40.442902639482725,40.442902639482725 0 0 0 81.99114759747292,25.427580514871032 V12.532383284044531 a9.108315894326587,9.108315894326587 0 0 0 -8.811305593424633,-9.306322761594556 h-4.950171681699231 a9.108315894326587,9.108315894326587 0 0 0 -8.811305593424633,9.306322761594556 v12.895197230826497 a40.17064319698927,40.17064319698927 0 0 0 -9.331073620003052,4.0591407789933704 l-8.613298726156664,-9.108315894326587 a8.489544434114185,8.489544434114185 0 0 0 -12.375429204248078,0 L25.58394128451018,23.967279868769744 a9.727087354538993,9.727087354538993 0 0 0 0,13.167456673319956 L34.19724001066683,46.243052436416285 a45.07131316187151,45.07131316187151 0 0 0 -3.6631270444574313,9.083565035918088 h-12.375429204248078 a9.083565035918088,9.083565035918088 0 0 0 -8.811305593424633,9.306322761594556 v5.197680265784193 a9.108315894326587,9.108315894326587 0 0 0 8.811305593424633,9.306322761594556 h11.979415469712139 a45.69008462208391,45.69008462208391 0 0 0 4.0591407789933704,10.642869115653347 l-8.613298726156664,9.108315894326587 a9.727087354538993,9.727087354538993 0 0 0 0,13.167456673319956 l3.465120177189462,3.6631270444574313 a8.489544434114185,8.489544434114185 0 0 0 12.375429204248078,0 l8.613298726156664,-9.108315894326587 a40.49240435629971,40.49240435629971 0 0 0 9.331073620003052,4.0591407789933704 v12.895197230826497 a9.083565035918088,9.083565035918088 0 0 0 8.811305593424633,9.306322761594556 h4.950171681699231 a9.108315894326587,9.108315894326587 0 0 0 8.811305593424633,-9.306322761594556 V111.94156456968378 a40.49240435629971,40.49240435629971 0 0 0 9.331073620003052,-4.0591407789933704 l8.613298726156664,9.108315894326587 a8.489544434114185,8.489544434114185 0 0 0 12.375429204248078,0 l3.465120177189462,-3.6631270444574313 a9.727087354538993,9.727087354538993 0 0 0 0,-13.167456673319956 l-8.613298726156664,-9.108315894326587 A45.54157947163293,45.54157947163293 0 0 0 110.87540530968797,80.62329596969856 h12.375429204248078 a9.083565035918088,9.083565035918088 0 0 0 8.811305593424633,-9.306322761594556 v-5.197680265784193 a9.108315894326587,9.108315894326587 0 0 0 -8.811305593424633,-9.306322761594556"/>
                </svg>
            </button>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="landing-hero">
        <div id="image_seal_container">
            <img src="assets/images/CSMP_logo.png" alt="CSMP Server Logo" class="landing-hero-logo">
        </div>
        
        <div id="launch_content">
            <button id="launch_button" class="btn-minecraft btn-green-mc">
                <span id="launch_details_text" style="display: none;"></span>
                <span class="btn-inner"><%- lang('landing.launchButton') %></span>
            </button>
        </div>
        
        <div id="launch_details" style="display: none;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                <span style="font-weight: bold; color: var(--text-dark); font-size: 11px;"><%- lang('landing.launchDetails') %></span>
                <span id="launch_progress_label" style="font-weight: bold; font-size: 11px;">0%</span>
            </div>
            <progress id="launch_progress" value="0" max="100"></progress>
        </div>
    </section>

    <!-- Footer Status Widgets -->
    <footer class="landing-footer">
        <div id="server_status_wrapper" class="status-block">
            <span class="status-label" id="landingPlayerLabel"><%- lang('landing.serverStatus') %></span>
            <span id="player_count" style="color: var(--mc-green); font-size: 14px;"><%- lang('landing.serverStatusPlaceholder') %></span>
        </div>
        
        <div id="mojangStatusWrapper" class="status-block">
            <span class="status-label"><%- lang('landing.mojangStatus') %></span>
            <div style="display: flex; align-items: center; gap: 8px;">
                <span id="mojang_status_icon" style="font-size: 16px;">&#8226;</span>
                <span>Services</span>
            </div>
            
            <div id="mojangStatusTooltip" style="display: none;">
                <div id="mojangStatusTooltipTitle"><%- lang('landing.mojangStatusTooltipTitle') %></div>
                <div id="mojangStatusEssentialContainer"></div>
                <div id="mojangStatusNEContainer">
                    <div id="mojangStatusNETitle"><%- lang('landing.mojangStatusNETitle') %></div>
                </div>
                <div id="mojangStatusNonEssentialContainer"></div>
            </div>
        </div>
    </footer>

    <script src="./assets/js/scripts/landing.js"></script>
</div>
